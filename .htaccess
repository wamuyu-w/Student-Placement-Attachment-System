<IfModule mod_rewrite.c>
    RewriteEngine On

    # Stop processing if the request is for a real file in the root
    # This ensures that assets/ and other root files are served directly
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    # If the URL already starts with public/, let it pass through to public/.htaccess
    # This prevents double-prefixing (public/public/...)
    RewriteRule ^public/ - [L]

    # Send all other requests to the public/ folder
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
