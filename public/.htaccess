<IfModule mod_rewrite.c>
    RewriteEngine On
#this makes your app and routes work without the need for index.php in the URL(don't touch it :(  )
    # Stop processing if the request is for a real file or directory
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Redirect everything else to index.php
    RewriteRule ^ index.php [QSA,L]
</IfModule>
